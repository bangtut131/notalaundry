generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== MULTI-TENANT =====

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  plan      Plan     @default(STARTER)
  isActive  Boolean  @default(true)
  planStart DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  customers Customer[]
  services  Service[]
  orders    Order[]
  expenses  Expense[]
}

enum Plan {
  STARTER
  STARTUP
  PRO
  ENTERPRISE
}

// ===== AUTH =====

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(KASIR)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

enum Role {
  SUPERADMIN
  ADMIN
  KASIR
  KURIR
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String?
  point     Int      @default(0)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@unique([phone, storeId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  unit        UnitType @default(KG)
  isExpress   Boolean  @default(false)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

enum UnitType {
  KG
  PCS
  METER
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  totalAmount   Float
  discount      Float       @default(0)
  finalAmount   Float
  paymentStatus PaymentStatus @default(UNPAID)
  status        OrderStatus @default(QUEUE)
  notes         String?
  
  createdAt     DateTime    @default(now())
  estimatedDate DateTime?
  completedDate DateTime?
  pickedUpDate  DateTime?
  updatedAt     DateTime    @updatedAt

  items OrderItem[]
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
}

enum OrderStatus {
  QUEUE
  WASHING
  IRONING
  READY
  COMPLETED
  CANCELLED
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  quantity  Float
  subtotal  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime @default(now())
  category    ExpenseCategory @default(OPERATIONAL)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ExpenseCategory {
  OPERATIONAL
  UTILITY
  SALARY
  OTHER
}
